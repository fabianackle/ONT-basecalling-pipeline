apptainer {
    enabled     = true
    pullTimeout = '1 h'
    //cacheDir    = '/home/user/data/nf-apptainer/' //
    autoMounts  = true
    runOptions  = '--nv'
}


process {
    cpus     = 8
    executor = 'slurm'
    shell    = ['/bin/bash', '-euo', 'pipefail']
    withName: DORADO {
        clusterOptions = '--gpus=1 --constraint="GPUMEM80GB|GPUMEM96GB|GPUMEM140GB"'
        memory         = '64 GB'
        time           = { 30.min * params.gigabases }
    }
    withName: DEMUX {
        memory = '8 GB'
        time   = '1h'
    }
}
