apptainer {
    enabled     = true
    pullTimeout = '1 h'
    //cacheDir    = '/home/user/data/nf-apptainer/' // adjust caching directory
    autoMounts  = true
    runOptions  = '--nv'
}


process {
    cpus     = 8
    executor = 'slurm'
    shell    = ['/bin/bash', '-euo', 'pipefail']
    withLabel: dorado {
        container = 'nanoporetech/dorado:shac8f356489fa8b44b31beba841b84d2879de2088e' // dorado 1.4.0
    }
    withName: DORADO {
        clusterOptions = '--gpus=1 --constraint="GPUMEM80GB|GPUMEM96GB|GPUMEM140GB"' // either A100, H100, or H200
        memory         = '64 GB'
        time           = { 30.min * params.gigabases }
    }
    withName: DEMUX {
        memory = '8 GB'
        time   = '1h'
    }
}
